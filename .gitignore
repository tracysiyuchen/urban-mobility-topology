# =========================
# Data (ignore all processed data by default)
# =========================
data/processed/*
data/raw/*
data/interim/*

# Allow ONLY selected analysis outputs (figures)
!data/processed/analysis/
!data/processed/analysis/**/*.png
!data/processed/analysis/**/*.jpg
!data/processed/analysis/**/*.jpeg
!data/processed/analysis/**/*.html

